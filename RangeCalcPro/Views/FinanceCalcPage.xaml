<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RangeCalcPro"
             x:Class="RangeCalcPro.FinanceCalcPage"
             Title="Финансовый подсчёт">
    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Оставляем только Clicked в XAML, подписка в коде НЕ нужна -->
        <Button x:Name="AddButton" 
                Grid.Row="0" 
                Text="Добавить строку" 
                Clicked="OnAddItemClicked"                 
                WidthRequest="200"
                HorizontalOptions="Center" />

        <!-- ДОБАВЛЯЕМ ItemsSource -->
        <CollectionView Grid.Row="1" 
                        x:Name="ItemsCollectionView" 
                        ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <HorizontalStackLayout Spacing="10" Padding="15">
                        <Entry Text="{Binding Amount, StringFormat='{}'}" 
                                Placeholder="Сумма" Keyboard="Numeric" WidthRequest="100" />
                        <Entry Text="{Binding Name}" Placeholder="Название" WidthRequest="250" />
                        <Button Text="удалить" 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:FinanceCalcPage}}, Path=DeleteCommand}" 
                                CommandParameter="{Binding .}" />
                    </HorizontalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Padding="15" Spacing="5">
            <Button Text="Рассчитать итог" 
                    Clicked="OnCalculateClicked" 
                    WidthRequest="200" 
                    HorizontalOptions="Center" />
            <Label x:Name="TotalAmountLabel" Text="Сумма: 0,00 ₽" FontAttributes="Bold" />
            <Label x:Name="TotalRankLabel" Text="Ранг: 0,00" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>