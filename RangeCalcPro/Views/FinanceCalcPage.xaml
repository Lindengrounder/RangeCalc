<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:RangeCalcPro"
             x:Class="RangeCalcPro.FinanceCalcPage"
             Title="Финансовый подсчёт">
    <Grid RowDefinitions="Auto,*,Auto">
        <Button x:Name="AddButton" 
                Grid.Row="0" 
                Text="Добавить строку" 
                Clicked="OnAddItemClicked"                 
                WidthRequest="200"
                HorizontalOptions="Center" />

        <CollectionView Grid.Row="1" 
                        x:Name="ItemsCollectionView" 
                        ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="Auto,*,Auto" 
                          ColumnSpacing="5" 
                          Padding="10,5">
                        <Entry Grid.Column="0" 
                               Text="{Binding Amount, StringFormat='{}'}" 
                               Placeholder="Сумма" 
                               Keyboard="Numeric" 
                               WidthRequest="100" />
                        <Entry Grid.Column="1" 
                               Text="{Binding Name}" 
                               Placeholder="Название" />
                        <Button Grid.Column="2" 
                                Text="X" 
                                Command="{Binding Source={RelativeSource AncestorType={x:Type local:FinanceCalcPage}}, Path=DeleteCommand}" 
                                CommandParameter="{Binding .}" 
                                WidthRequest="50" 
                                HeightRequest="40" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Padding="15" Spacing="5">
            <Button Text="Рассчитать итог" 
                    Clicked="OnCalculateClicked" 
                    WidthRequest="200" 
                    HorizontalOptions="Center" />
            <!--Button Text="Сохранить в файл" 
                    Clicked="OnSaveToFileClicked" 
                    WidthRequest="200" 
                    HorizontalOptions="Center" 
                    Margin="0,10,0,0" /-->
            <Label x:Name="TotalAmountLabel" Text="Сумма: 0,00 ₽" FontAttributes="Bold" />
            <Label x:Name="TotalRankLabel" Text="Ранг: 0,00" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>