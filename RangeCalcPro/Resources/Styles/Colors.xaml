<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Основные акцентные цвета -->
    <Color x:Key="Primary">#6B7F59</Color>
    <!-- приглушённый оливково-зелёный -->
    <Color x:Key="PrimaryDark">#4A5A3C</Color>
    <!-- тёмный оливковый -->
    <Color x:Key="PrimaryDarkText">#C5CFB8</Color>
    <!-- светлый бежево-зелёный для текста на тёмном -->
    <Color x:Key="Secondary">#B9B0A3</Color>
    <!-- тёплый серо-бежевый -->
    <Color x:Key="SecondaryDarkText">#DED6CC</Color>
    <!-- очень светлый бежевый для второстепенного текста -->
    <Color x:Key="Tertiary">#EFEAE2</Color>
    <!-- светлый тёплый серый для фона -->

    <!-- Базовые цвета -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#241F1A</Color>
    <Color x:Key="Magenta">#A67C6B</Color>
    <!-- тёплый терракотовый (замена малиновому) -->
    <Color x:Key="MidnightBlue">#3A332C</Color>
    <!-- тёмный шоколадный вместо синего -->
    <Color x:Key="OffBlack">#2A241E</Color>
    <!-- почти чёрный тёплый оттенок -->

    <!-- Оттенки серого (тёплые, с бежевым подтоном) -->
    <Color x:Key="Gray100">#F9F6F0</Color>
    <Color x:Key="Gray200">#EFEAE2</Color>
    <Color x:Key="Gray300">#DCD5CC</Color>
    <Color x:Key="Gray400">#B8ADA1</Color>
    <Color x:Key="Gray500">#968B7F</Color>
    <Color x:Key="Gray600">#71675C</Color>
    <Color x:Key="Gray900">#241F1A</Color>
    <Color x:Key="Gray950">#16120E</Color>

    <!-- Кисти -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>