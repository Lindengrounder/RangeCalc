<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->
    <!-- Основные акцентные цвета -->
    <Color x:Key="Primary">#FF3946</Color>
    <!-- красный -->
    <Color x:Key="PrimaryDark">#9B2CFF</Color>
    <!-- бордовый -->
    <Color x:Key="PrimaryDarkText">#004Ff1</Color>
    <!-- оранжевый для текста на тёмном -->
    <Color x:Key="Secondary">#C2ff5B</Color>
    <!-- малиновый -->
    <Color x:Key="SecondaryDarkText">#EffF51</Color>
    <!-- светло-оранжевый -->
    <Color x:Key="Tertiary">#F4A2ff</Color>
    <!-- оранжевый -->

    <!-- Базовые цвета -->
    <Color x:Key="White">#99FFFF</Color>
    <Color x:Key="Black">#000099</Color>
    <Color x:Key="Magenta">#D690AA</Color>
    <!-- оставлен, но не используется -->
    <Color x:Key="MidnightBlue">#5D1A1A</Color>
    <!-- тёмно-бордовый (был синий) -->
    <Color x:Key="OffBlack">#3A0E0E</Color>
    <!-- очень тёмный красный -->

    <!-- Оттенки серого (теплее, с лёгким красным подтоном) -->
    <Color x:Key="Gray100">#00E4E4</Color>
    <Color x:Key="Gray200">#00C6C6</Color>
    <Color x:Key="Gray300">#00A0A0</Color>
    <Color x:Key="Gray400">#007B7B</Color>
    <Color x:Key="Gray500">#005C5C</Color>
    <Color x:Key="Gray600">#004242</Color>
    <Color x:Key="Gray900">#001E1E</Color>
    <Color x:Key="Gray950">#001212</Color>

    <!-- Кисти для совместимости -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>