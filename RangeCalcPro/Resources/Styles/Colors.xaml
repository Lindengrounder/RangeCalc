<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Основные акцентные цвета -->
    <Color x:Key="Primary">#2C6E9E</Color>
    <!-- приглушённый синий -->
    <Color x:Key="PrimaryDark">#1E4A6B</Color>
    <!-- тёмно-синий -->
    <Color x:Key="PrimaryDarkText">#8BA9C5</Color>
    <!-- светлый сине-серый для текста на тёмном фоне -->
    <Color x:Key="Secondary">#5FA8D3</Color>
    <!-- светло-синий акцент -->
    <Color x:Key="SecondaryDarkText">#A0C4E2</Color>
    <!-- ещё более светлый для второстепенного текста -->
    <Color x:Key="Tertiary">#E9ECF0</Color>
    <!-- очень светлый серо-синий для фона/рамок -->

    <!-- Базовые цвета -->
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#101828</Color>
    <Color x:Key="Magenta">#B5478C</Color>
    <!-- приглушённый розовый для редких акцентов -->
    <Color x:Key="MidnightBlue">#1E2A3A</Color>
    <!-- глубокий тёмно-синий -->
    <Color x:Key="OffBlack">#1D2939</Color>
    <!-- почти чёрный с синим отливом -->

    <!-- Оттенки серого (холодные, чистые) -->
    <Color x:Key="Gray100">#F5F7FA</Color>
    <Color x:Key="Gray200">#E9ECF0</Color>
    <Color x:Key="Gray300">#D0D5DD</Color>
    <Color x:Key="Gray400">#98A2B3</Color>
    <Color x:Key="Gray500">#667085</Color>
    <Color x:Key="Gray600">#475467</Color>
    <Color x:Key="Gray900">#101828</Color>
    <Color x:Key="Gray950">#0C111D</Color>

    <!-- Кисти для совместимости -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource Secondary}"/>
    <SolidColorBrush x:Key="TertiaryBrush" Color="{StaticResource Tertiary}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

    <SolidColorBrush x:Key="Gray100Brush" Color="{StaticResource Gray100}"/>
    <SolidColorBrush x:Key="Gray200Brush" Color="{StaticResource Gray200}"/>
    <SolidColorBrush x:Key="Gray300Brush" Color="{StaticResource Gray300}"/>
    <SolidColorBrush x:Key="Gray400Brush" Color="{StaticResource Gray400}"/>
    <SolidColorBrush x:Key="Gray500Brush" Color="{StaticResource Gray500}"/>
    <SolidColorBrush x:Key="Gray600Brush" Color="{StaticResource Gray600}"/>
    <SolidColorBrush x:Key="Gray900Brush" Color="{StaticResource Gray900}"/>
    <SolidColorBrush x:Key="Gray950Brush" Color="{StaticResource Gray950}"/>
</ResourceDictionary>